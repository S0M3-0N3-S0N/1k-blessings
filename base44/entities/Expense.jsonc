{
  "name": "Expense",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "title": "Description"
    },
    "amount": {
      "type": "number",
      "title": "Amount",
      "default": 0
    },
    "category": {
      "type": "string",
      "title": "Category",
      "enum": [
        "supplies",
        "cleaning",
        "software",
        "utilities",
        "marketing",
        "equipment",
        "other"
      ],
      "default": "other"
    },
    "expense_date": {
      "type": "string",
      "title": "Expense Date (YYYY-MM-DD)"
    },
    "paid_by": {
      "type": "string",
      "title": "Paid By",
      "enum": [
        "owner",
        "salon"
      ],
      "default": "salon"
    },
    "receipt_note": {
      "type": "string",
      "title": "Receipt Note"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    }
  },
  "required": [
    "description",
    "amount",
    "expense_date"
  ]
}
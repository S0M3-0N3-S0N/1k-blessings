{
  "name": "SalonNote",
  "type": "object",
  "properties": {
    "content": {
      "type": "string",
      "title": "Content"
    },
    "pinned": {
      "type": "boolean",
      "title": "Pinned",
      "default": false
    },
    "category": {
      "type": "string",
      "title": "Category",
      "enum": [
        "general",
        "reminder",
        "policy",
        "goal"
      ],
      "default": "general"
    }
  },
  "required": [
    "content"
  ]
}
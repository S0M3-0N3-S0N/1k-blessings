{
  "name": "Renter",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Name"
    },
    "role": {
      "type": "string",
      "title": "Role",
      "default": "Stylist"
    },
    "payment_model": {
      "type": "string",
      "title": "Payment Model",
      "enum": [
        "rent",
        "commission"
      ],
      "default": "rent"
    },
    "rent_amount": {
      "type": "number",
      "title": "Rent Amount",
      "default": 0
    },
    "frequency": {
      "type": "string",
      "title": "Frequency",
      "enum": [
        "weekly",
        "biweekly",
        "monthly"
      ],
      "default": "weekly"
    },
    "commission_owner": {
      "type": "number",
      "title": "Owner Commission %",
      "default": 40,
      "minimum": 0,
      "maximum": 100
    },
    "base_salary": {
      "type": "number",
      "title": "Base Salary ($)",
      "default": 0
    },
    "base_salary_frequency": {
      "type": "string",
      "title": "Base Salary Frequency",
      "enum": [
        "weekly",
        "monthly"
      ],
      "default": "weekly"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    },
    "phone": {
      "type": "string",
      "title": "Phone"
    },
    "start_date": {
      "type": "string",
      "title": "Start Date (YYYY-MM-DD)"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    },
    "user_email": {
      "type": "string",
      "title": "Linked User Email"
    }
  },
  "required": [
    "name",
    "payment_model"
  ]
}